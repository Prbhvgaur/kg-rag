GEMINI_API_KEY=your_gemini_api_key_from_aistudio
NEO4J_URI=neo4j+s://xxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_aura_password
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=your_supabase_anon_key
# For local development on IPv4-only or mixed networks, prefer the Supavisor Session pooler
# string from Supabase Dashboard > Connect instead of the direct db.<ref>.supabase.co host.
# Example:
# SUPABASE_DB_URL=postgresql://postgres.<project-ref>:password@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require
SUPABASE_DB_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres
ALLOWED_ORIGINS=http://localhost:5173,https://your-app.vercel.app
MAX_FILE_SIZE_MB=20
MAX_CHUNKS_PER_DOC=500
GEMINI_RPM_LIMIT=14
ENVIRONMENT=development
